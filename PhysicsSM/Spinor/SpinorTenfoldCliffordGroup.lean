namespace PhysicsSM.Spinor.SpinorTenfold

/-! ## The Clifford action as a linear endomorphism -/

/-- The Clifford action of `v : V10`, packaged as a linear endomorphism of
the Fock spinor space. Multiplication in `Module.End Ōäé FockSpinor` is
composition, so `gammaEnd v * gammaEnd w` is "act by `w`, then by `v`". -/
def gammaEnd (v : V10) : Module.End Ōäé FockSpinor where
  toFun := cliffordAction v
  map_add' := cliffordAction_add_spinor v
  map_smul' c psi := cliffordAction_smul_spinor c v psi

@[simp] theorem gammaEnd_apply (v : V10) (psi : FockSpinor) :
    gammaEnd v psi = cliffordAction v psi := rfl

/-- `gammaEnd` is additive in the vector argument. -/
theorem gammaEnd_add (v w : V10) : gammaEnd (v + w) = gammaEnd v + gammaEnd w := by
  refine LinearMap.ext fun psi => ?_
  simp [cliffordAction_add_vec]

/-- `gammaEnd` is homogeneous in the vector argument. -/
theorem gammaEnd_smul (c : Ōäé) (v : V10) : gammaEnd (c ŌĆó v) = c ŌĆó gammaEnd v := by
  refine LinearMap.ext fun psi => ?_
  simp [cliffordAction_smul_vec]

@[simp] theorem gammaEnd_zero : gammaEnd (0 : V10) = 0 := by
  refine LinearMap.ext fun psi => ?_
  simp

/-- The Clifford square relation in endomorphism form:
`gammaEnd v * gammaEnd v = Q10 v ŌĆó 1`. This is the trusted
`cliffordAction_cliffordAction_self` of `SpinorTenfoldCAR`. -/
theorem gammaEnd_mul_self (v : V10) :
    gammaEnd v * gammaEnd v = Q10 v ŌĆó (1 : Module.End Ōäé FockSpinor) := by
  refine LinearMap.ext fun psi => ?_
  simp [Module.End.mul_apply, cliffordAction_cliffordAction_self]

/-- The polarized Clifford relation in endomorphism form:
`gammaEnd v * gammaEnd w + gammaEnd w * gammaEnd v = B10 v w ŌĆó 1`. -/
theorem gammaEnd_mul_anticomm (v w : V10) :
    gammaEnd v * gammaEnd w + gammaEnd w * gammaEnd v
      = B10 v w ŌĆó (1 : Module.End Ōäé FockSpinor) := by
  refine LinearMap.ext fun psi => ?_
  simp [Module.End.mul_apply, cliffordAction_anticomm]

/-! ## Clifford units of anisotropic vectors -/

/-- The Clifford operator of an anisotropic vector (`Q10 v ŌēĀ 0`) as a unit
of the endomorphism ring: the inverse is `(Q10 v)Ōü╗┬╣ ŌĆó gammaEnd v` by the
Clifford square relation. -/
def gammaUnit (v : V10) (hv : Q10 v ŌēĀ 0) : (Module.End Ōäé FockSpinor)╦Ż where
  val := gammaEnd v
  inv := (Q10 v)Ōü╗┬╣ ŌĆó gammaEnd v
  val_inv := by
    rw [mul_smul_comm, gammaEnd_mul_self, smul_smul, inv_mul_cancelŌéĆ hv, one_smul]
  inv_val := by
    rw [smul_mul_assoc, gammaEnd_mul_self, smul_smul, inv_mul_cancelŌéĆ hv, one_smul]

@[simp] theorem gammaUnit_val (v : V10) (hv : Q10 v ŌēĀ 0) :
    (gammaUnit v hv : Module.End Ōäé FockSpinor) = gammaEnd v := rfl

@[simp] theorem gammaUnit_inv_val (v : V10) (hv : Q10 v ŌēĀ 0) :
    (((gammaUnit v hv)Ōü╗┬╣ : (Module.End Ōäé FockSpinor)╦Ż) : Module.End Ōäé FockSpinor)
      = (Q10 v)Ōü╗┬╣ ŌĆó gammaEnd v := rfl

/-! ## The even Clifford group -/

/-- The generating set of the even Clifford group: products of **two**
anisotropic Clifford units. Even products preserve chirality (each single
`gammaEnd` flips it); products of two reflections generate the special
orthogonal action on vectors. -/
def pairUnitSet : Set (Module.End Ōäé FockSpinor)╦Ż :=
  {g | Ōłā (v w : V10) (hv : Q10 v ŌēĀ 0) (hw : Q10 w ŌēĀ 0),
    g = gammaUnit v hv * gammaUnit w hw}

/-- The even Clifford group `GSpin(10, Ōäé)` in its spinor representation:
the subgroup of units of `Module.End Ōäé FockSpinor` generated by products
of two anisotropic Clifford units.

Note: this contains all nonzero scalars (`scalarUnit_mem`), so it is the
**general** spin group, not `Spin(10)` itself; see the module docstring. -/
def evenCliffordGroup : Subgroup (Module.End Ōäé FockSpinor)╦Ż :=
  Subgroup.closure pairUnitSet

/-- Pair products of anisotropic Clifford units generate (hence belong to)
the even Clifford group. -/
theorem gammaUnit_mul_gammaUnit_mem (v w : V10) (hv : Q10 v ŌēĀ 0) (hw : Q10 w ŌēĀ 0) :
    gammaUnit v hv * gammaUnit w hw Ōłł evenCliffordGroup :=
  Subgroup.subset_closure Ō¤©v, w, hv, hw, rflŌ¤®

/-! ## Mode-flip vectors and units -/

/-- The hyperbolic mode-flip vector `e_i + f_i`: creation coefficient `1`
and annihilation coefficient `1` at index `i`, zero elsewhere. It is
anisotropic with `Q10 (flipVec i) = 1`, and its Clifford operator toggles
the occupation of mode `i` on basis spinors (proved in the basis-orbit
draft module). -/
def flipVec (i : Fin 5) : V10 :=
  (fun j => if j = i then 1 else 0, fun j => if j = i then 1 else 0)

@[simp] theorem Q10_flipVec (i : Fin 5) : Q10 (flipVec i) = 1 := by
  simp [Q10, flipVec]

/-- The mode-flip Clifford unit at index `i`. -/
def flipUnit (i : Fin 5) : (Module.End Ōäé FockSpinor)╦Ż :=
  gammaUnit (flipVec i) (by rw [Q10_flipVec]; exact one_ne_zero)

@[simp] theorem flipUnit_val (i : Fin 5) :
    (flipUnit i : Module.End Ōäé FockSpinor) = gammaEnd (flipVec i) := rfl

/-- Products of two mode flips lie in the even Clifford group. -/
theorem flipUnit_mul_flipUnit_mem (i j : Fin 5) :
    flipUnit i * flipUnit j Ōłł evenCliffordGroup :=
  gammaUnit_mul_gammaUnit_mem _ _ _ _

/-- The index bookkeeping for a mode flip: toggle membership of `i` in `T`.
`gammaEnd (flipVec i)` carries `basisSpinor T` to
`opSign i T ŌĆó basisSpinor (flipSet i T)` (basis-orbit draft module). -/
def flipSet (i : Fin 5) (T : Finset (Fin 5)) : Finset (Fin 5) :=
  if i Ōłł T then T.erase i else insert i T

/-! ## Scalars inside the even Clifford group -/

/-- Every nonzero scalar `c` is realized in the even Clifford group as the
pair product `gammaUnit (c ŌĆó flipVec 0) * gammaUnit (flipVec 0)`, whose
value is `c ŌĆó 1` (`scalarUnit_val`). This is the scale freedom that makes
*marked* (not merely projective) transitivity statements available. -/
def scalarUnit (c : Ōäé) (hc : c ŌēĀ 0) : (Module.End Ōäé FockSpinor)╦Ż :=
  gammaUnit (c ŌĆó flipVec 0)
      (by rw [Q10_smul, Q10_flipVec, mul_one]; exact pow_ne_zero 2 hc)
    * gammaUnit (flipVec 0) (by rw [Q10_flipVec]; exact one_ne_zero)

theorem scalarUnit_mem (c : Ōäé) (hc : c ŌēĀ 0) : scalarUnit c hc Ōłł evenCliffordGroup :=
  gammaUnit_mul_gammaUnit_mem _ _ _ _

@[simp] theorem scalarUnit_val (c : Ōäé) (hc : c ŌēĀ 0) :
    (scalarUnit c hc : Module.End Ōäé FockSpinor) = c ŌĆó (1 : Module.End Ōäé FockSpinor) := by
  rw [scalarUnit, Units.val_mul, gammaUnit_val, gammaUnit_val, gammaEnd_smul,
    smul_mul_assoc, gammaEnd_mul_self, Q10_flipVec, one_smul]

/-! ## The twisted reflection -/

/-- The twisted reflection of `u` in the anisotropic vector `v`:
`reflectTwist v u = (B10 u v / Q10 v) ŌĆó v - u`. Conjugating `gammaEnd u`
by `gammaUnit v` produces exactly `gammaEnd (reflectTwist v u)` (proved in
the conjugation draft module); it is minus the usual `B10`-orthogonal
reflection in the hyperplane `v^ŌŖź`, preserves `B10` and `Q10`, and is an
involution.

When `Q10 v = 0` the value is junk (`division by zero`); every theorem
about `reflectTwist` carries the hypothesis `Q10 v ŌēĀ 0`. -/
def reflectTwist (v u : V10) : V10 := (B10 u v / Q10 v) ŌĆó v - u

/-! ## Chirality preservation -/

/-- An endomorphism preserves chirality if it maps even spinors to even
spinors and odd spinors to odd spinors. Every element of
`evenCliffordGroup` does (conjugation draft module): each generator is a
product of two chirality-*flipping* Clifford operators. -/
def PreservesChirality (g : Module.End Ōäé FockSpinor) : Prop :=
  (ŌłĆ psi, IsEvenSpinor psi ŌåÆ IsEvenSpinor (g psi))
    Ōł¦ (ŌłĆ psi, IsOddSpinor psi ŌåÆ IsOddSpinor (g psi))

